# ── Shopify Shop-Domain ──────────────────────────────────────────
# Deine myshopify.com Domain (ohne https://)
SHOPIFY_STORE_DOMAIN=dein-shop.myshopify.com

# ── Storefront API (Warenkorb / Konfigurator-Proxy) ─────────────
# EMPFOHLEN: Headless-Kanal → Storefront → „Private access token“
# Siehe docs/STOREFRONT_SETUP.md und docs/SHOPIFY_SETUP_ANLEITUNG.md
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# Optional (Legacy): öffentlicher Storefront-Token – nur EINES der beiden setzen:
# Wenn PRIVATE gesetzt ist, wird ACCESS ignoriert.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ── API-Version Storefront ─────────────────────────────────────
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# ── Client Credentials (nur für tools/fetch-variant-ids.js / Admin API) ─
# Dev Dashboard: https://dev.shopify.com/dashboard → Apps → eure App → Settings
# App muss auf dem Shop installiert sein. Liefert Admin-Token (z. B. für GraphQL Admin).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── API-Version Admin (fetch-variant-ids) ──────────────────────
SHOPIFY_API_VERSION=2025-01

# ── CORS: erlaubte Browser-Origins für POST /api/shopify-storefront ─
# Mehrere Einträge kommagetrennt (exakt wie die Origin in den DevTools, inkl. Port).
# Beispiel lokal + Shop + ggf. Custom-Domain:
# SOLAR_ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://dein-shop.myshopify.com
SOLAR_ALLOWED_ORIGIN=http://localhost:3000
