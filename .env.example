# Vercel / lokal (Serverless api/shopify-storefront.js)
SHOPIFY_STORE_DOMAIN=dein-shop.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_oder_storefront_token_aus_app
SHOPIFY_STOREFRONT_API_VERSION=2024-10

