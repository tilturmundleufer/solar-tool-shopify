# ── Shopify Shop-Domain ──────────────────────────────────────────
# Deine myshopify.com Domain (ohne https://) – z. B. für tools/fetch-variant-ids.js
SHOPIFY_STORE_DOMAIN=dein-shop.myshopify.com

# ── Warenkorb (Konfigurator) ─────────────────────────────────────
# Der Konfigurator nutzt Cart-Permalinks (kein Storefront-API-Proxy mehr).
# Shop-Origin setzt ihr clientseitig: window.SOLAR_SHOP_ORIGIN in index.html
# (oder im Theme vor dem iframe), z. B. https://dein-shop.myshopify.com

# ── Optional: Storefront-Tokens (nur für tools/create-storefront-token.js o. Ä.) ─
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# ── Client Credentials (nur für tools/fetch-variant-ids.js / Admin API) ─
# Dev Dashboard: https://dev.shopify.com/dashboard → Apps → eure App → Settings
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-01
