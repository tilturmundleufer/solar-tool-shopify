{% comment %}
  Solar-Konfigurator – Theme Section
  ────────────────────────────────────────────────────────────────────────────
  Einbinden:
    1. Als "sections/solar-konfigurator.liquid" ins Theme (Themes → Code bearbeiten → sections)
    2. Section im Theme Editor auf die Seite legen (z. B. „Solar-Konfigurator“-Seite)

  Warenkorb (Cart-Permalink):
    Bei iframe: Vercel sendet postMessage(solar:cartRedirect) an diese Seite; das Script unten
    führt window.location zur Cart-URL aus (nicht im iframe – Shopify blockt frame-ancestors).
    Auf Vercel: window.SOLAR_SHOP_ORIGIN in index.html. Siehe docs/THEME_BRIDGE.md
  ────────────────────────────────────────────────────────────────────────────
{% endcomment %}

<section
  id="solar-konfigurator-section"
  class="solar-konfigurator-section page-width{% if section.settings.display_mode == 'iframe' %} solar-konfigurator-section--tight{% endif %}"
  style="padding: {{ section.settings.vertical_padding }}px {% if section.settings.display_mode == 'iframe' %}8px{% else %}0{% endif %};"
>
  {% if section.settings.show_heading %}
    <div class="solar-konfigurator-header" style="text-align: {{ section.settings.heading_align }}; margin-bottom: 1.5rem;">
      <h2 class="solar-konfigurator-title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="solar-konfigurator-sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.display_mode == 'iframe' %}
    {%- comment -%}
      Start-Höhe aus Theme; Konfigurator meldet per postMessage (solar:iframeHeight) die benötigte Höhe –
      Shop passt iframe an → kein Scrollen innerhalb des iframe nötig (bis max. ca. 95% Fensterhöhe).
    {%- endcomment -%}
    <div
      class="solar-konfigurator-iframe-wrapper"
      style="position: relative; width: 100%; min-height: {{ section.settings.iframe_height }}px; border: none;"
    >
      <iframe
        class="solar-konfigurator-iframe"
        src="{{ section.settings.konfigurator_url }}"
        title="Solar-Konfigurator"
        style="width: 100%; height: {{ section.settings.iframe_height }}px; border: 0; border-radius: {{ section.settings.border_radius }}px; display: block;"
        loading="lazy"
        allow="clipboard-write"
        referrerpolicy="origin"
      ></iframe>
    </div>

  {% else %}
    {%- comment -%} Button/Link: Konfigurator auf Vercel; Warenkorb per Permalink wie im iframe. ── {%- endcomment -%}
    <div class="solar-konfigurator-cta" style="text-align: {{ section.settings.heading_align }};">
      <a
        href="{{ section.settings.konfigurator_url }}"
        class="button button--primary solar-konfigurator-btn"
        {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        style="
          display: inline-block;
          padding: 14px 32px;
          font-size: 1.1rem;
          font-weight: 600;
          text-decoration: none;
          border-radius: {{ section.settings.border_radius }}px;
          background-color: {{ section.settings.button_color }};
          color: {{ section.settings.button_text_color }};
        "
      >
        {{ section.settings.button_label }}
      </a>
      {% if section.settings.button_note != blank %}
        <p style="margin-top: 0.75rem; font-size: 0.9rem; opacity: 0.7;">{{ section.settings.button_note }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.konfigurator_url != blank %}
    <script>
      (function () {
        var cfgUrl = {{ section.settings.konfigurator_url | json }};
        var sectionEl = document.getElementById('solar-konfigurator-section');
        function isCartDrawerDebugEnabled() {
          try {
            if (window.SOLAR_DEBUG_CART_DRAWER === true) return true;
            if (window.localStorage && window.localStorage.getItem('solar_debug_cart_drawer') === '1') return true;
            return /(?:\?|&)solarCartDebug=1(?:&|$)/.test(window.location.search || '');
          } catch (_) {
            return false;
          }
        }
        var cartDebug = isCartDrawerDebugEnabled();
        function cartDebugLog(step, payload) {
          if (!cartDebug || !window.console || typeof window.console.info !== 'function') return;
          try {
            window.console.info('[SolarCartBridge]', step, payload || {});
          } catch (_) {}
        }
        function allowedOrigin() {
          try {
            return new URL(cfgUrl).origin;
          } catch (e) {
            return '';
          }
        }
        function sendHandledAck(event) {
          try {
            if (event && event.source && typeof event.source.postMessage === 'function') {
              event.source.postMessage({ type: 'solar:cartHandled' }, event.origin);
              cartDebugLog('ack-sent', { origin: event.origin });
            }
          } catch (_) {}
        }
        function getSolarIframe() {
          return sectionEl ? sectionEl.querySelector('iframe.solar-konfigurator-iframe') : null;
        }
        function normalizeVatSegment(segment) {
          return segment === 'business' ? 'business' : 'private';
        }
        function readVatContext(detail) {
          var api = window.customerVatContext;
          var bootstrap = window.__VAT_CUSTOMER_BOOTSTRAP || {};
          var segment = detail && detail.segment;
          var tag = detail && detail.tag;
          if (!segment && api && typeof api.getSegment === 'function') {
            try {
              segment = api.getSegment();
            } catch (_) {}
          }
          if (!segment) return null;
          segment = normalizeVatSegment(segment);
          if (!tag && api && typeof api.getSegmentTag === 'function') {
            try {
              tag = api.getSegmentTag(segment);
            } catch (_) {}
          }
          return {
            type: 'solar:vatContext',
            segment: segment,
            tag: typeof tag === 'string' ? tag : '',
            locked: Boolean((detail && detail.locked) || bootstrap.companyLockedBusiness)
          };
        }
        function pushVatSegmentToSolarIframe(detail) {
          var origin = allowedOrigin();
          var iframe = getSolarIframe();
          var payload = readVatContext(detail);
          if (!origin || !iframe || !iframe.contentWindow || !payload) return false;
          try {
            iframe.contentWindow.postMessage(payload, origin);
            cartDebugLog('vat-context-sent', payload);
            return true;
          } catch (_) {
            return false;
          }
        }
        function scheduleVatContextPush() {
          var attempts = 0;
          function tick() {
            if (pushVatSegmentToSolarIframe()) return;
            attempts += 1;
            if (attempts < 40) window.setTimeout(tick, 125);
          }
          tick();
        }
        function openConfiguredCartDrawer() {
          var opened = false;
          var drawer = document.querySelector('.cart-drawer[data-cart-drawer]');
          var panel = drawer ? drawer.querySelector('.cart-drawer__panel') : null;

          // Theme-spezifische Cart-Events
          try {
            document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true, detail: { open: true, source: 'solar-konfigurator' } }));
            document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: { source: 'solar-konfigurator' } }));
            document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true, detail: { source: 'solar-konfigurator' } }));
            document.dispatchEvent(new CustomEvent('cart-drawer:open', { bubbles: true, detail: { source: 'solar-konfigurator' } }));
            cartDebugLog('events-dispatched');
          } catch (_) {}

          // Versuche den vorhandenen Header-Trigger zu nutzen (öffnet Drawer in Theme-JS)
          var trigger = document.querySelector('.header__cart-btn, .header__cart-icon-mobile');
          if (trigger) {
            try {
              var clickEvt = new MouseEvent('click', { bubbles: true, cancelable: true, view: window });
              var notCancelled = trigger.dispatchEvent(clickEvt);
              if (!notCancelled) opened = true; // Theme hat Klick übernommen (typisch mit preventDefault)
              cartDebugLog('header-trigger-dispatched', { notCancelled: notCancelled, opened: opened });
            } catch (_) {}
          } else {
            cartDebugLog('header-trigger-missing');
          }

          // Direkter Fallback über bekannte Drawer-Struktur
          if (drawer) {
            try {
              drawer.setAttribute('aria-hidden', 'false');
              drawer.classList.add('is-open', 'open', 'active');
              document.documentElement.classList.add('cart-drawer-open');
              document.body.classList.add('cart-drawer-open');
              if (panel && typeof panel.focus === 'function') panel.focus();
              opened = true;
              cartDebugLog('drawer-opened-via-dom', { selector: '.cart-drawer[data-cart-drawer]' });
            } catch (_) {}
          } else {
            cartDebugLog('drawer-element-missing');
          }

          cartDebugLog('open-result', { opened: opened });
          return opened;
        }
        async function tryDrawerCartFromPermalink(url) {
          try {
            cartDebugLog('permalink-fetch-start', { url: url });
            await fetch(url, {
              method: 'GET',
              credentials: 'same-origin',
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            cartDebugLog('permalink-fetch-success');
          } catch (_) {
            cartDebugLog('permalink-fetch-failed');
            return false;
          }
          if (openConfiguredCartDrawer()) return true;
          await new Promise(function (resolve) { setTimeout(resolve, 120); });
          return openConfiguredCartDrawer();
        }
        window.addEventListener('message', function (event) {
          var ao = allowedOrigin();
          if (!ao || event.origin !== ao) return;
          var d = event.data;
          if (!d || typeof d !== 'object') return;
          cartDebugLog('message-received', { type: d.type, origin: event.origin });

          if (d.type === 'solar:cartRedirect' && typeof d.url === 'string') {
            sendHandledAck(event);
            (async function () {
              var opened = await tryDrawerCartFromPermalink(d.url);
              if (!opened) {
                cartDebugLog('fallback-full-cart-redirect', { url: d.url });
                window.location.href = d.url;
              } else {
                cartDebugLog('drawer-opened-successfully');
              }
            })();
            return;
          }

          if (d.type === 'solar:iframeHeight' && typeof d.height === 'number' && sectionEl) {
            var iframe = sectionEl.querySelector('iframe.solar-konfigurator-iframe');
            if (!iframe) return;
            var maxPx = Math.round(window.innerHeight * 0.95);
            var h = Math.min(Math.max(Math.round(d.height), 400), maxPx, 5600);
            iframe.style.height = h + 'px';
            var wrap = sectionEl.querySelector('.solar-konfigurator-iframe-wrapper');
            if (wrap) wrap.style.minHeight = h + 'px';
          }
        });
        var solarIframe = getSolarIframe();
        if (solarIframe) {
          solarIframe.addEventListener('load', scheduleVatContextPush);
        }
        document.addEventListener('vat:segment-change', function (event) {
          var detail = event && event.detail ? event.detail : null;
          pushVatSegmentToSolarIframe(detail);
        });
        scheduleVatContextPush();
      })();
    </script>
  {% endif %}
</section>

<style>
  .solar-konfigurator-section { width: 100%; }
  /* iframe: Dawn page-width begrenzt Breite und addiert Rand – volle Breite nutzen, Rand nur über Section-Padding (8px) */
  #solar-konfigurator-section.solar-konfigurator-section--tight.page-width {
    max-width: 100%;
  }
  .solar-konfigurator-title { font-size: 1.8rem; font-weight: 700; margin: 0 0 0.5rem; }
  .solar-konfigurator-sub { font-size: 1.05rem; opacity: 0.8; margin: 0; }
  @media (max-width: 749px) {
    .solar-konfigurator-title { font-size: 1.4rem; }
    /* iframe-Höhe kommt von postMessage (solar:iframeHeight) – kein !important gegen inline style */
    .solar-konfigurator-iframe-wrapper { min-height: 70vh; }
  }
</style>

{% schema %}
{
  "name": "Solar-Konfigurator",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Konfigurator-URL"
    },
    {
      "type": "url",
      "id": "konfigurator_url",
      "label": "URL des Solar-Konfigurators (Vercel)",
      "info": "z. B. https://solar-tool-shopify.vercel.app — ohne abschließenden Slash"
    },
    {
      "type": "header",
      "content": "Einbindung & Shopify-Warenkorb"
    },
    {
      "type": "paragraph",
      "content": "iframe: postMessage vom Konfigurator – diese Section enthält den Listener (Theme-Datei aktuell halten). Vercel index.html: SOLAR_SHOP_ORIGIN = Shop-URL. Konfigurator-URL muss exakt der iframe-src entsprechen (Origin-Check). docs/THEME_BRIDGE.md"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Anzeige-Modus",
      "options": [
        {
          "value": "button",
          "label": "Button / Link (Konfigurator auf Vercel)"
        },
        {
          "value": "iframe",
          "label": "iframe (eingebettet – Warenkorb per Permalink)"
        }
      ],
      "default": "button",
      "info": "So prüfen: Theme Editor → diese Section → Feld „Anzeige-Modus“. iframe = eingebettetes Vercel-Fenster."
    },
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Überschrift anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Solaranlage konfigurieren"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile (optional)",
      "default": "Stellen Sie Ihre Solaranlage zusammen – Komponenten werden direkt in den Warenkorb gelegt."
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Ausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button-Einstellungen (Modus: Button)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Solar-Konfigurator →"
    },
    {
      "type": "text",
      "id": "button_note",
      "label": "Hinweis unter Button (optional)",
      "default": "Kostenlos & ohne Anmeldung"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "In neuem Tab öffnen",
      "default": false
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button-Farbe",
      "default": "#1a6b3c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button-Textfarbe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "iframe-Einstellungen (nur wenn Modus „iframe“)"
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "iframe Start-Höhe (px)",
      "info": "Wird nach Laden durch den Konfigurator per Nachricht angepasst. Nur Fallback / erster Paint.",
      "min": 400,
      "max": 2000,
      "step": 50,
      "default": 1100
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertikaler Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Eckenradius (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Solar-Konfigurator"
    }
  ]
}
{% endschema %}
